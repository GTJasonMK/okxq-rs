{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "OKX Quantitative Trading",
  "version": "0.1.0",
  "identifier": "com.okxquant.rust",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OKX Quantitative Trading",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "backgroundColor": "#1a1a2e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
