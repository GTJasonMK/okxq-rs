{
  "name": "okxq-rs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OKX Quantitative desktop app rebuilt with Rust and Tauri",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:no-hmr": "node scripts/dev.mjs --no-hot-reload",
    "dev:tauri": "tauri dev",
    "dev:cleanup": "node scripts/cleanup-dev.mjs",
    "dev:frontend": "vite --host 127.0.0.1",
    "build": "tauri build",
    "build:frontend": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test:frontend": "vitest run",
    "test:frontend:watch": "vitest",
    "smoke:gui": "scripts/smoke/tauri_gui_smoke.sh",
    "type-check": "vue-tsc --noEmit",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-notification": "^2.3.0",
    "lightweight-charts": "^5.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vite": "^7.2.7",
    "vitest": "^3.1.0",
    "vue-tsc": "^2.2.0"
  }
}
